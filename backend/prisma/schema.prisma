// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
}

enum SubmissionStatus {
  PENDING
  ON_PROCESS
  APPROVED
  REJECTED
  COMPLETED
}

enum GeneratedLetterStatus {
  DRAFT
  ISSUED
  ARCHIVED
}

model User {
  id               String   @id @default(uuid())
  name             String
  nik              String   @unique
  familyCardNumber String   @map("family_card_number") 
  email            String   @unique
  phoneNumber      String   @unique @map("phone_number")
  address          String
  role             UserRole @default(USER)
  password         String
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]
  notifications Notification[]
  submissions   Submission[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  header    String
  body      String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

model LetterCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  letterTypes LetterType[]

  @@map("letter_categories")
}

model LetterType {
  id               String   @id @default(uuid())
  letterCategoryId String   @map("letter_category_id")
  name             String
  description      String?
  templatePath     String?  @map("template_path")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  letterCategory LetterCategory @relation(fields: [letterCategoryId], references: [id], onDelete: Restrict)
  submissions    Submission[]

  @@index([letterCategoryId])
  @@map("letter_types")
}

model Submission {
  id           String           @id @default(uuid())
  userId       String           @map("user_id")
  letterTypeId String           @map("letter_type_id")
  status       SubmissionStatus @default(PENDING)
  purpose      String
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  user            User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  letterType      LetterType       @relation(fields: [letterTypeId], references: [id], onDelete: Restrict)
  documents       Document[]
  generatedLetters GeneratedLetter[]

  @@index([userId])
  @@index([letterTypeId])
  @@map("submissions")
}

model Document {
  id           String   @id @default(uuid())
  submissionId String   @map("submission_id")
  documentType String   @map("document_type")
  storagePath  String   @map("storage_path")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("documents")
}

model GeneratedLetter {
  id           String                @id @default(uuid())
  submissionId String                @map("submission_id")
  letterNumber String?               @unique @map("letter_number")
  path         String
  status       GeneratedLetterStatus @default(DRAFT)
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Restrict)

  @@index([submissionId])

  @@map("generated_letters")
}